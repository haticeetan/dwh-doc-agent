# Oracle Veritabanı Bağlantısı
DB_USER=your_oracle_username
DB_PASSWORD=your_oracle_password
DB_HOST=your_host_or_ip
DB_PORT=1521

# DB_SERVICE veya DB_SID'den birini doldur, diğerini boş bırak
DB_SERVICE=your_service_name
DB_SID=

# Oracle Instant Client kurulum dizini
ORACLE_CLIENT_LIB=C:\path\to\instantclient

# OpenAI API
OPENAI_API_KEY=sk-proj-...

# Loglama (DEBUG | INFO | WARNING | ERROR | CRITICAL) — varsayılan: INFO
LOG_LEVEL=INFO

# Distributed Tracing
# OTEL_EXPORTER=console           → span'lar terminale basılır (geliştirme)
# OTEL_EXPORTER=otlp              → Jaeger / Zipkin / Azure Monitor'a gönderilir
OTEL_EXPORTER=console
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# CORS — frontend kaynak adresleri (virgülle ayır)
# Üretim ortamında gerçek domain adresini yaz
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
